---
import BaseLayout from './BaseLayout.astro';

interface Props {
    title: string;
    description: string;
    category: string;
    categoryColor: string;
    date: string;
    readTime: string;
    wordCount: string;
    author?: string;
    prevPost?: { title: string; slug: string };
    nextPost?: { title: string; slug: string };
}

const {
    title,
    description,
    category,
    categoryColor = 'var(--color-brand)',
    date,
    readTime,
    wordCount,
    author = 'Badmouth Digital',
    prevPost,
    nextPost,
} = Astro.props;
---

<BaseLayout title={title} description={description} currentPage="transmissions">

    <!-- ARTICLE HERO -->
    <section class="post-hero surface-base noise-bg">
        <div class="grid-page">
            <div class="col-content stack-4">
                <div class="post-hero__meta">
                    <a href="/transmissions" class="post-hero__back">← All Transmissions</a>
                    <span class="post-hero__category" style={`color: ${categoryColor}; border-color: ${categoryColor};`}>{category}</span>
                </div>
                <h1 class="t-display t-display--hero post-hero__title">{title}</h1>
                <p class="t-body t-body--lg post-hero__desc">{description}</p>
                <div class="post-meta-bar">
                    <div class="post-meta-bar__item">
                        <span class="post-meta-bar__label">Published</span>
                        <span class="post-meta-bar__value">{date}</span>
                    </div>
                    <div class="post-meta-bar__divider"></div>
                    <div class="post-meta-bar__item">
                        <span class="post-meta-bar__label">Read Time</span>
                        <span class="post-meta-bar__value">{readTime}</span>
                    </div>
                    <div class="post-meta-bar__divider"></div>
                    <div class="post-meta-bar__item">
                        <span class="post-meta-bar__label">Word Count</span>
                        <span class="post-meta-bar__value">{wordCount}</span>
                    </div>
                    <div class="post-meta-bar__divider"></div>
                    <div class="post-meta-bar__item">
                        <span class="post-meta-bar__label">By</span>
                        <span class="post-meta-bar__value">{author}</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ARTICLE BODY + TOC SIDEBAR -->
    <section class="post-body surface-sunken">
        <div class="post-layout">
            <!-- Table of Contents Sidebar -->
            <aside class="post-toc" id="post-toc">
                <div class="post-toc__sticky">
                    <p class="post-toc__title">TABLE OF CONTENTS</p>
                    <nav class="post-toc__nav" id="toc-nav">
                        <!-- Populated by JS -->
                    </nav>
                    <div class="post-toc__progress">
                        <div class="post-toc__progress-bar" id="reading-progress"></div>
                    </div>
                </div>
            </aside>

            <!-- Article Content -->
            <article class="post-content" id="post-content">
                <slot />
            </article>
        </div>
    </section>

    <!-- ARTICLE NAVIGATION -->
    <section class="post-nav surface-base">
        <div class="grid-page">
            <div class="col-content">
                <div class="post-nav__grid">
                    {prevPost ? (
                        <a href={`/transmissions/${prevPost.slug}`} class="post-nav__link post-nav__link--prev">
                            <span class="post-nav__label">← Previous</span>
                            <span class="post-nav__title">{prevPost.title}</span>
                        </a>
                    ) : <div></div>}
                    {nextPost ? (
                        <a href={`/transmissions/${nextPost.slug}`} class="post-nav__link post-nav__link--next">
                            <span class="post-nav__label">Next →</span>
                            <span class="post-nav__title">{nextPost.title}</span>
                        </a>
                    ) : <div></div>}
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section section--cta section--padded section--mic-drop has-scanlines" style="position: relative;">
        <div class="grid-page" style="position: relative; z-index: 2;">
            <div class="col-content text-center stack-4">
                <h2 class="t-display t-display--section" style="color: #fff; margin-inline: auto;">
                    DONE READING?<br />
                    <span class="mic-drop__headline">LET'S FIX YOURS.</span>
                </h2>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 50ch; margin-top: var(--space-4);">
                    These posts give you the playbook. If you want someone to run it for you, that's what we do.
                </p>
                <a href="/contact" class="btn btn--lg">Diagnose Your System →</a>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    /* ── Post Hero ─────────────────────────────────── */
    .post-hero {
        padding: var(--space-20) 0 var(--space-12);
    }

    .post-hero__meta {
        display: flex;
        align-items: center;
        gap: var(--space-4);
    }

    .post-hero__back {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.2s;
    }
    .post-hero__back:hover {
        color: var(--color-brand);
    }

    .post-hero__category {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 3px 10px;
        border: 1px solid;
    }

    .post-hero__title {
        max-width: 20ch;
    }

    .post-hero__desc {
        max-width: 55ch;
        color: var(--color-text-secondary);
    }

    /* ── Meta Bar ──────────────────────────────────── */
    .post-meta-bar {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-4);
        align-items: center;
        padding: var(--space-4) 0;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
        margin-top: var(--space-2);
    }

    .post-meta-bar__item {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .post-meta-bar__label {
        font-family: var(--font-mono);
        font-size: 0.55rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--color-text-muted);
    }

    .post-meta-bar__value {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--color-text-primary);
    }

    .post-meta-bar__divider {
        width: 1px;
        height: 28px;
        background: var(--color-border);
    }

    /* ── Post Layout (TOC + Content) ───────────────── */
    .post-body {
        padding: var(--space-12) 0 var(--space-16);
    }

    .post-layout {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 var(--space-6);
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: var(--space-10);
    }

    @media (max-width: 900px) {
        .post-layout {
            grid-template-columns: 1fr;
        }
        .post-toc {
            display: none;
        }
    }

    /* ── Table of Contents ──────────────────────────── */
    .post-toc__sticky {
        position: sticky;
        top: 100px;
    }

    .post-toc__title {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--color-text-muted);
        margin-bottom: var(--space-4);
        padding-bottom: var(--space-2);
        border-bottom: 1px solid var(--color-border);
    }

    .post-toc__nav {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    :global(.post-toc__link) {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--color-text-muted);
        text-decoration: none;
        padding: 6px 0 6px 12px;
        border-left: 2px solid transparent;
        transition: all 0.2s ease;
        line-height: 1.4;
    }

    :global(.post-toc__link:hover) {
        color: var(--color-text-primary);
    }

    :global(.post-toc__link--active) {
        color: var(--color-brand) !important;
        border-left-color: var(--color-brand);
    }

    .post-toc__progress {
        margin-top: var(--space-6);
        height: 2px;
        background: var(--color-border);
        border-radius: 1px;
        overflow: hidden;
    }

    .post-toc__progress-bar {
        height: 100%;
        background: var(--color-brand);
        width: 0%;
        transition: width 0.1s ease;
    }

    /* ── Article Content Styling ────────────────────── */
    .post-content {
        max-width: 720px;
    }

    :global(.post-content h2) {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 700;
        text-transform: uppercase;
        color: var(--color-text-primary);
        margin-top: var(--space-10);
        margin-bottom: var(--space-4);
        padding-top: var(--space-6);
        border-top: 1px solid var(--color-border);
        scroll-margin-top: 100px;
    }

    :global(.post-content h3) {
        font-family: var(--font-display);
        font-size: clamp(1.1rem, 2vw, 1.4rem);
        font-weight: 700;
        text-transform: uppercase;
        color: var(--color-text-primary);
        margin-top: var(--space-6);
        margin-bottom: var(--space-3);
    }

    :global(.post-content p) {
        font-size: 1.05rem;
        line-height: 1.8;
        color: var(--color-text-secondary);
        margin-bottom: var(--space-4);
    }

    :global(.post-content strong) {
        color: var(--color-text-primary);
        font-weight: 600;
    }

    :global(.post-content ul),
    :global(.post-content ol) {
        margin-bottom: var(--space-4);
        padding-left: var(--space-6);
    }

    :global(.post-content li) {
        font-size: 1.05rem;
        line-height: 1.8;
        color: var(--color-text-secondary);
        margin-bottom: var(--space-2);
    }

    :global(.post-content blockquote) {
        border-left: 3px solid var(--color-brand);
        padding: var(--space-4) var(--space-6);
        margin: var(--space-6) 0;
        background: var(--color-surface-elevated);
    }

    :global(.post-content blockquote p) {
        color: var(--color-text-primary);
        font-weight: 500;
        font-style: italic;
        margin-bottom: 0;
    }

    :global(.post-content .callout) {
        background: var(--color-surface-elevated);
        border: 1px solid var(--color-border);
        padding: var(--space-5);
        margin: var(--space-6) 0;
    }

    :global(.post-content .callout-title) {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-brand);
        margin-bottom: var(--space-2);
    }

    :global(.post-content .post-image) {
        width: 100%;
        aspect-ratio: 16/9;
        background: var(--color-surface-elevated);
        border: 1px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: var(--space-6) 0;
        overflow: hidden;
    }

    :global(.post-content .post-image img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    :global(.post-content .post-image__placeholder) {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-text-muted);
    }

    :global(.post-content hr) {
        border: none;
        height: 1px;
        background: var(--color-border);
        margin: var(--space-8) 0;
    }

    /* ── Article Navigation ─────────────────────────── */
    .post-nav {
        padding: var(--space-8) 0;
        border-top: 1px solid var(--color-border);
    }

    .post-nav__grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-6);
    }

    @media (max-width: 600px) {
        .post-nav__grid {
            grid-template-columns: 1fr;
        }
    }

    .post-nav__link {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        padding: var(--space-5);
        border: 1px solid var(--color-border);
        text-decoration: none;
        transition: border-color 0.2s;
    }

    .post-nav__link:hover {
        border-color: var(--color-brand);
    }

    .post-nav__link--next {
        text-align: right;
    }

    .post-nav__label {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-brand);
    }

    .post-nav__title {
        font-family: var(--font-display);
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--color-text-primary);
        text-transform: uppercase;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const content = document.getElementById('post-content');
        const tocNav = document.getElementById('toc-nav');
        const progressBar = document.getElementById('reading-progress');
        if (!content || !tocNav) return;

        // Build TOC from h2 elements
        const headings = content.querySelectorAll('h2');
        headings.forEach((h, i) => {
            const id = h.id || `section-${i}`;
            h.id = id;
            const link = document.createElement('a');
            link.href = `#${id}`;
            link.className = 'post-toc__link';
            link.textContent = h.textContent;
            tocNav.appendChild(link);
        });

        // Active heading tracking + reading progress
        const tocLinks = tocNav.querySelectorAll('.post-toc__link');

        function updateActiveHeading() {
            let current = 0;
            headings.forEach((h, i) => {
                if (h.getBoundingClientRect().top <= 120) current = i;
            });
            tocLinks.forEach((l, i) => {
                l.classList.toggle('post-toc__link--active', i === current);
            });
        }

        function updateProgress() {
            if (!progressBar) return;
            const rect = content.getBoundingClientRect();
            const total = rect.height;
            const scrolled = Math.max(0, -rect.top);
            const pct = Math.min(100, (scrolled / (total - window.innerHeight)) * 100);
            progressBar.style.width = `${pct}%`;
        }

        window.addEventListener('scroll', () => {
            updateActiveHeading();
            updateProgress();
        }, { passive: true });
        updateActiveHeading();
    });
</script>
