---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Custom Builds | Badmouth Digital" description="When your operation is too complex for the standard system. Starting at $10,000." currentPage="custom-builds">

    <!-- SECTION 1 — CONTEXT HEADER -->
    <section class="section section--hero surface-base noise-bg has-scanlines" style="position: relative; min-height: auto; padding-top: var(--space-24); padding-bottom: var(--space-12);">
        <div class="grid-page">
            <div class="col-content stack-4 text-center">
                <div style="display: inline-flex; align-items: center; gap: 8px; margin-inline: auto;">
                    <span class="status-dot status-dot--live"></span>
                    <p class="t-eyebrow" style="margin: 0;">Custom Builds</p>
                </div>
                <h1 class="t-display t-display--hero" style="margin-inline: auto;">
                    WHEN YOUR OPERATION<br />
                    IS TOO COMPLEX FOR<br />
                    <span style="color: var(--theme-accent-yellow);">THE STANDARD SYSTEM.</span>
                </h1>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch;">
                    Multiple locations. Custom routing. Internal tools. Heavy integrations. Reporting across teams. Unique workflows nobody else has built for.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 600;">
                    Same methodology. Same foundation thinking. But built entirely around your operation.
                </p>
            </div>
        </div>
    </section>

    <!-- SECTION 2 — WHEN THIS MAKES SENSE -->
    <section class="section section--padded surface-sunken">
        <div class="grid-page grid-align-center grid-gap-lg">
            <div class="col-left-7 stack-4">
                <p class="t-eyebrow">When This Makes Sense</p>
                <h2 class="t-display t-display--section">
                    THIS ISN'T FOR EVERYONE.<br />
                    <span class="t-accent t-flicker">HERE'S WHO IT'S FOR.</span>
                </h2>
                <p class="t-body t-body--md" style="max-width: 55ch;">
                    If you're a solo operator or a small crew, the Foundation Install is your move. Custom Builds are for businesses that have outgrown off-the-shelf solutions.
                </p>
            </div>
            <div class="col-right-5">
                <div class="card stack-3" style="border-left: 3px solid var(--theme-accent-yellow);">
                    <p class="t-body t-body--sm" style="color: var(--theme-accent-yellow);">◉ Multiple service areas or locations</p>
                    <p class="t-body t-body--sm" style="color: var(--theme-accent-yellow);">◉ Lead routing to different teams or techs</p>
                    <p class="t-body t-body--sm" style="color: var(--theme-accent-yellow);">◉ Custom reporting across departments</p>
                    <p class="t-body t-body--sm" style="color: var(--theme-accent-yellow);">◉ Complex integrations (ERP, dispatch, scheduling)</p>
                    <p class="t-body t-body--sm" style="color: var(--theme-accent-yellow);">◉ Internal dashboards for management</p>
                    <p class="t-body t-body--sm" style="color: var(--theme-accent-yellow);">◉ Custom automation workflows</p>
                </div>
            </div>
        </div>
    </section>

    <!-- WHAT A CUSTOM BUILD LOOKS LIKE -->
    <section class="section section--padded surface-base">
        <div class="grid-page">
            <div class="col-content stack-6 text-center">
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    SAME SYSTEM THINKING.<br />
                    <span class="t-accent t-flicker">CUSTOM ARCHITECTURE.</span>
                </h2>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch;">
                    We audit your current operation, map the workflows, identify the gaps, and build a system designed around how your business actually runs — not how a template assumes it does.
                </p>
            </div>
        </div>
    </section>

    <!-- INVESTMENT -->
    <section class="section section--statement section--padded surface-elevated">
        <div class="grid-page">
            <div class="col-content stack-4 text-center">
                <p class="t-eyebrow">Investment</p>
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    STARTING AT <span style="color: var(--theme-accent-yellow);">$10,000.</span>
                </h2>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch;">
                    Custom builds are scoped individually. We'll map your operation, define the build, and give you a fixed price before anything starts.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 600;">
                    No surprises. No scope creep billing. One price. One build.
                </p>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section section--cta section--padded section--mic-drop section--mic-drop--yellow has-scanlines" style="position: relative;">
        <div class="grid-page" style="position: relative; z-index: 2;">
            <div class="col-content text-center stack-4">
                <h2 class="t-display t-display--section" style="color: #fff; margin-inline: auto;">
                    NEED SOMETHING<br />
                    <span class="mic-drop__headline">CUSTOM?</span>
                </h2>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 50ch; margin-top: var(--space-4);">
                    Tell us what your operation looks like. We'll tell you what we'd build.
                </p>
                <a href="/contact" class="btn btn--lg" style="margin-top: var(--space-4);">Let's Talk About Your Build →</a>
            </div>
        </div>
    </section>

</BaseLayout>
