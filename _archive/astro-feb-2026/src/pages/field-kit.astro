---
import BaseLayout from '../layouts/BaseLayout.astro';

const diagnosticTools = [
    {
        title: "Marketing System Checklist",
        description: "Find out what's connected and what's not. Takes 5 minutes. Tells you exactly where the gaps are.",
        type: "Free Download",
        icon: "☐",
    },
    {
        title: "Website Scorecard",
        description: "Rate your current site across 10 categories: lead capture, speed, mobile, follow-up, tracking, and more.",
        type: "Free Download",
        icon: "▣",
    },
    {
        title: "Ad Spend Calculator",
        description: "Plug in your numbers. Find out if your ads are making money or just making noise.",
        type: "Free Tool",
        icon: "◈",
    },
];

const guides = [
    {
        title: "Google Business Profile Setup",
        description: "Step-by-step guide to getting your Google profile dialed in. Categories, photos, posts, reviews. The whole thing.",
        type: "Guide",
        icon: "📍",
    },
    {
        title: "Is Your Website Actually Working?",
        description: "A no-BS walkthrough of what your website should be doing behind the scenes. Spoiler: most aren't.",
        type: "Guide",
        icon: "⚙",
    },
    {
        title: "How to Hire an Agency (Without Getting Burned)",
        description: "What to ask. What to avoid. Red flags that should stop you cold. Written by someone who's seen it all.",
        type: "Guide",
        icon: "🚩",
    },
];
---

<BaseLayout title="Field Kit" description="Free tools, checklists, and guides for local service businesses. Fix what's broken before you hire anyone." currentPage="field-kit">

    <!-- SECTION 1 — HERO -->
    <section class="section section--hero surface-base noise-bg" style="min-height: auto; padding-top: var(--space-24); padding-bottom: var(--space-12);">
        <div class="grid-page">
            <div class="col-content stack-6 text-center">
                <p class="t-eyebrow">Free Tools</p>
                <h1 class="t-display t-display--hero" style="margin-inline: auto;">
                    THE <span style="color: var(--color-brand);">FIELD KIT.</span><br />
                    FIX WHAT YOU CAN.<br />
                    <span style="color: var(--color-brand);">WE'LL HANDLE THE REST.</span>
                </h1>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch;">
                    Not ready to hire? Fine. Here's some free stuff that'll actually help. No email required for most of it. No catch.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch;">
                    Use these to figure out what's broken. If you need help fixing it, you know where to find us.
                </p>
            </div>
        </div>
    </section>


    <!-- SECTION 2 — DIAGNOSTIC TOOLS -->
    <section class="section section--padded surface-sunken">
        <div class="grid-page grid-gap-lg">
            <div class="col-full text-center stack-6">
                <p class="t-eyebrow">Figure Out What's Broken</p>
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    RUN YOUR OWN <span class="t-accent t-flicker">DIAGNOSTIC.</span>
                </h2>
            </div>
            <div class="col-full">
                <div class="inner-grid-3">
                    {diagnosticTools.map((tool) => (
                        <div class="card stack-4 kit-card">
                            <div class="kit-card__header">
                                <span class="kit-card__icon">{tool.icon}</span>
                                <span class="kit-card__type">{tool.type}</span>
                            </div>
                            <h3 class="t-display t-display--card">{tool.title}</h3>
                            <p class="t-body t-body--sm">{tool.description}</p>
                            <a href="/contact" class="btn btn--primary btn--sm" style="margin-top: auto;">Get It →</a>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 3 — GUIDES -->
    <section class="section section--padded surface-base">
        <div class="grid-page grid-gap-lg">
            <div class="col-full text-center stack-6">
                <p class="t-eyebrow">Learn the Basics</p>
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    DO IT <span class="t-accent t-flicker">YOURSELF.</span> (FOR NOW.)
                </h2>
            </div>
            <div class="col-full">
                <div class="inner-grid-3">
                    {guides.map((guide) => (
                        <div class="card stack-4 kit-card">
                            <div class="kit-card__header">
                                <span class="kit-card__icon">{guide.icon}</span>
                                <span class="kit-card__type">{guide.type}</span>
                            </div>
                            <h3 class="t-display t-display--card">{guide.title}</h3>
                            <p class="t-body t-body--sm">{guide.description}</p>
                            <a href="/contact" class="btn btn--outline btn--sm" style="margin-top: auto;">Download →</a>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 4 — CTA -->
    <section class="section section--cta section--padded section--mic-drop has-scanlines" style="position: relative;">
        <div class="grid-page" style="position: relative; z-index: 2;">
            <div class="col-content text-center stack-4">
                <h2 class="t-display t-display--section" style="color: #fff; margin-inline: auto;">
                    USE WHAT YOU CAN.<br />
                    <span class="mic-drop__headline">ASK US ABOUT THE REST.</span>
                </h2>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 50ch; margin-top: var(--space-4);">
                    These tools will get you started. But if you want someone to build the whole system, that's what we do.
                </p>
                <div class="flex-row-wrap" style="gap: var(--space-4); justify-content: center;">
                    <a href="/services" class="btn btn--lg">See Our Services →</a>
                    <a href="/contact" class="btn btn--lg" style="background: transparent; border: 2px solid #fff;">Or Just Talk to Us →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- REINFORCEMENT -->
    <section class="section section--statement section--padded-sm surface-pure">
        <div class="grid-page">
            <div class="col-content text-center">
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 500;">
                    Free tools that actually help. No email wall. No bait-and-switch. Just use them.
                </p>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    .kit-card {
        border: 1px solid var(--color-border);
        transition: border-color 0.2s ease;
    }

    .kit-card:hover {
        border-color: var(--color-brand);
    }

    .kit-card__header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-bottom: var(--space-3);
        border-bottom: 1px solid var(--color-border);
    }

    .kit-card__icon {
        font-size: 1.25rem;
    }

    .kit-card__type {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--color-text-muted);
        border: 1px solid var(--color-border);
        padding: 2px 8px;
    }
</style>
