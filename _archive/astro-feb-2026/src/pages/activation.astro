---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Activation Campaigns | Badmouth Digital" description="You've got money hiding in your business. We help you find it. Revenue activation campaigns for local service businesses." currentPage="activation">

    <!-- SECTION 1 — CONTEXT HEADER -->
    <section class="section section--hero surface-base noise-bg has-scanlines" style="position: relative; min-height: auto; padding-top: var(--space-24); padding-bottom: var(--space-12);">
        <div class="grid-page">
            <div class="col-content stack-4 text-center">
                <div style="display: inline-flex; align-items: center; gap: 8px; margin-inline: auto;">
                    <span class="status-dot status-dot--live"></span>
                    <p class="t-eyebrow" style="margin: 0;">Activation Campaigns</p>
                </div>
                <h1 class="t-display t-display--hero" style="margin-inline: auto;">
                    YOU'VE GOT MONEY<br />
                    <span style="color: var(--theme-accent-orange, var(--color-brand));">HIDING IN YOUR BUSINESS.</span>
                </h1>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 600;">
                    We help you find it.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch;">
                    Past customers who haven't heard from you. Estimates that never closed. Seasonal services nobody's promoting. Referrals that never got asked for.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 600;">
                    Revenue activation campaigns use your existing database and your system to extract money that's already there.
                </p>
            </div>
        </div>
    </section>

    <!-- SECTION 2 — REAL EXAMPLE -->
    <section class="section section--padded surface-sunken">
        <div class="grid-page grid-align-center grid-gap-lg">
            <div class="col-left-7 stack-4">
                <p class="t-eyebrow">Real Example</p>
                <h2 class="t-display t-display--section">
                    HVAC COMPANY.<br />
                    <span class="t-accent t-crt-shake" style="color: var(--color-brand);">$14,400 IN 10 DAYS.</span>
                </h2>
                <p class="t-body t-body--md" style="max-width: 55ch;">
                    340 past customers. One email and text campaign: "Spring Tune-Up Special — 15% Off for Past Customers."
                </p>
                <p class="t-body t-body--md" style="max-width: 55ch;">
                    No ad spend. No landing page. No new lead gen. Just hitting the people who already know, like, and trust them.
                </p>
            </div>
            <div class="col-right-5">
                <div class="card stack-3" style="border-left: 3px solid var(--color-brand); padding: var(--space-6);">
                    <p style="font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-text-muted); margin-bottom: var(--space-3);">Campaign Results</p>
                    <div class="stack-2">
                        <div style="display: flex; justify-content: space-between; align-items: baseline;">
                            <span class="t-body t-body--sm">Contacts Reached</span>
                            <span class="t-body t-body--sm" style="color: var(--color-text-primary); font-weight: 700;">340</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: baseline;">
                            <span class="t-body t-body--sm">Appointments Booked</span>
                            <span class="t-body t-body--sm" style="color: var(--color-text-primary); font-weight: 700;">36</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: baseline;">
                            <span class="t-body t-body--sm">Revenue Generated</span>
                            <span class="t-body t-body--sm" style="color: var(--color-brand); font-weight: 700;">$14,400</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: baseline;">
                            <span class="t-body t-body--sm">Ad Spend</span>
                            <span class="t-body t-body--sm" style="color: var(--color-text-primary); font-weight: 700;">$0</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: baseline;">
                            <span class="t-body t-body--sm">Time to Results</span>
                            <span class="t-body t-body--sm" style="color: var(--color-text-primary); font-weight: 700;">10 days</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 3 — CAMPAIGN CATEGORIES -->
    <section class="section section--padded surface-base">
        <div class="grid-page grid-gap-lg">
            <div class="col-full text-center stack-4">
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    FOUR WAYS TO <span class="t-accent t-flicker">ACTIVATE REVENUE.</span>
                </h2>
            </div>
            <div class="col-full">
                <div class="inner-grid-2">
                    <!-- Category 1 -->
                    <div class="card stack-3" style="border-top: 3px solid var(--color-brand);">
                        <h3 class="t-display t-display--card">GET PAST CUSTOMERS BACK</h3>
                        <div class="stack-2">
                            <p class="t-body t-body--sm">◉ Seasonal tune-up campaigns</p>
                            <p class="t-body t-body--sm">◉ "We miss you" re-engagement</p>
                            <p class="t-body t-body--sm">◉ Annual maintenance reminders</p>
                            <p class="t-body t-body--sm">◉ Loyalty offers for repeat business</p>
                        </div>
                    </div>
                    <!-- Category 2 -->
                    <div class="card stack-3" style="border-top: 3px solid var(--theme-accent-teal);">
                        <h3 class="t-display t-display--card">RECOVER LOST REVENUE</h3>
                        <div class="stack-2">
                            <p class="t-body t-body--sm">◉ Abandoned estimate follow-up</p>
                            <p class="t-body t-body--sm">◉ "Still interested?" sequences</p>
                            <p class="t-body t-body--sm">◉ Price-drop or financing offers</p>
                            <p class="t-body t-body--sm">◉ Re-quote expired proposals</p>
                        </div>
                    </div>
                    <!-- Category 3 -->
                    <div class="card stack-3" style="border-top: 3px solid var(--theme-accent-yellow);">
                        <h3 class="t-display t-display--card">GROW WHAT YOU'VE GOT</h3>
                        <div class="stack-2">
                            <p class="t-body t-body--sm">◉ Referral campaigns</p>
                            <p class="t-body t-body--sm">◉ Review request pushes</p>
                            <p class="t-body t-body--sm">◉ Upsell/cross-sell sequences</p>
                            <p class="t-body t-body--sm">◉ New service announcements</p>
                        </div>
                    </div>
                    <!-- Category 4 -->
                    <div class="card stack-3" style="border-top: 3px solid var(--color-brand);">
                        <h3 class="t-display t-display--card">OWN YOUR NEIGHBORHOOD</h3>
                        <div class="stack-2">
                            <p class="t-body t-body--sm">◉ Neighborhood saturation campaigns</p>
                            <p class="t-body t-body--sm">◉ "Just finished a job near you"</p>
                            <p class="t-body t-body--sm">◉ Local event sponsorship follow-up</p>
                            <p class="t-body t-body--sm">◉ Seasonal awareness blasts</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 4 — HOW ACTIVATION WORKS WITH THE SYSTEM -->
    <section class="section section--statement section--padded surface-elevated">
        <div class="grid-page">
            <div class="col-content stack-4 text-center">
                <p class="t-eyebrow">How It Works</p>
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    YOUR SYSTEM ALREADY HAS <span class="t-accent t-flicker">THE DATA.</span>
                </h2>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch;">
                    Activation campaigns use your CRM data, past customer list, and existing automations. We build the campaign, load the sequences, and fire. Your system does the rest.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 600;">
                    No new tools. No third-party platform. Just your system, doing what it was built for.
                </p>
            </div>
        </div>
    </section>

    <!-- INVESTMENT -->
    <section class="section section--statement section--padded surface-base">
        <div class="grid-page">
            <div class="col-content stack-4 text-center">
                <p class="t-eyebrow">Investment</p>
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    CAMPAIGNS START AT <span style="color: var(--color-brand);">$500.</span>
                </h2>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch;">
                    One-time campaign fee. We build it, load it, and run it through your system. You keep the revenue.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 600;">
                    Most campaigns pay for themselves in the first 48 hours.
                </p>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section section--cta section--padded section--mic-drop has-scanlines" style="position: relative;">
        <div class="grid-page" style="position: relative; z-index: 2;">
            <div class="col-content text-center stack-4">
                <h2 class="t-display t-display--section" style="color: #fff; margin-inline: auto;">
                    READY TO ACTIVATE<br />
                    <span class="mic-drop__headline">HIDDEN REVENUE?</span>
                </h2>
                <div style="display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap; margin-top: var(--space-4);">
                    <a href="/contact" class="btn btn--lg">Tell Us What You've Got →</a>
                    <a href="/foundation-install" class="btn btn--lg btn--mic-outline">Need The Foundation First?</a>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>
