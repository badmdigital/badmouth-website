---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Volume — Paid Ads That Work | Badmouth Digital" description="Turn up the dial. Your system's ready for it. $1,500/month + $1,000 minimum ad spend." currentPage="volume">

    <!-- SECTION 1 — CONTEXT HEADER -->
    <section class="section section--hero surface-base noise-bg has-scanlines" style="position: relative; min-height: auto; padding-top: var(--space-24); padding-bottom: var(--space-12);">
        <div class="grid-page">
            <div class="col-content stack-4 text-center">
                <div style="display: inline-flex; align-items: center; gap: 8px; margin-inline: auto;">
                    <span class="status-dot status-dot--live"></span>
                    <p class="t-eyebrow" style="margin: 0;">Layer 3: Volume</p>
                </div>
                <h1 class="t-display t-display--hero" style="margin-inline: auto;">
                    TURN UP<br />
                    <span style="color: var(--theme-accent-yellow);">THE DIAL.</span>
                </h1>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 600;">
                    Your system's ready for it.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch;">
                    Google Ads. Meta Ads. Targeted campaigns that send traffic into a system that's already catching and converting.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 600;">
                    This isn't gambling on clicks. This is feeding a machine that already works.
                </p>
            </div>
        </div>
    </section>

    <!-- SECTION 2 — PROBLEM WITH ADS ALONE -->
    <section class="section section--statement section--padded surface-sunken">
        <div class="grid-page grid-align-center">
            <div class="col-left-7 stack-4">
                <p class="t-eyebrow">The Problem</p>
                <h2 class="t-display t-display--section">
                    ADS DON'T FIX<br />
                    <span class="t-accent t-crt-shake">BROKEN SYSTEMS.</span>
                </h2>
                <p class="t-body t-body--md" style="max-width: 55ch;">
                    "Spend $3K/month. Get 200 clicks. 12 calls. Close 2 jobs." Sound familiar?
                </p>
                <p class="t-body t-body--md" style="max-width: 55ch;">
                    If your landing page doesn't convert, if nobody follows up fast enough, if you can't track what came from what — then ads are just an expensive way to confirm that nothing works.
                </p>
                <p class="t-body t-body--md" style="max-width: 55ch; color: var(--color-text-primary); font-weight: 600;">
                    Volume is Layer 3. It comes after the Foundation is built and Visibility is in motion.
                </p>
            </div>
            <div class="col-right-5">
                <div class="retro-box" style="padding: var(--space-6);">
                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: var(--space-4); padding-bottom: var(--space-3); border-bottom: 1px solid var(--color-border);">
                        <span style="color: var(--theme-accent-yellow); font-size: 0.85rem;">⚠</span>
                        <span style="font-family: var(--font-mono); font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--theme-accent-yellow);">ORDER OF OPERATIONS</span>
                    </div>
                    <div class="stack-2" style="font-family: var(--font-mono); font-size: 0.75rem;">
                        <p style="color: var(--theme-accent-teal);">✓ Foundation installed</p>
                        <p style="color: var(--theme-accent-teal);">✓ System catching and converting</p>
                        <p style="color: var(--theme-accent-teal);">✓ Visibility building organic</p>
                        <p style="color: var(--theme-accent-yellow); margin-top: var(--space-3);">→ NOW add Volume</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 3 — WHAT YOU GET -->
    <section class="section section--padded surface-base">
        <div class="grid-page grid-gap-lg">
            <div class="col-full text-center stack-4">
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    ADS THAT FEED <span class="t-accent t-flicker">A SYSTEM.</span>
                </h2>
            </div>
            <div class="col-full">
                <div class="inner-grid-3">
                    <div class="card stack-3" style="border-left: 3px solid var(--theme-accent-yellow);">
                        <h3 class="t-display t-display--card">GOOGLE ADS</h3>
                        <p class="t-body t-body--sm">Search ads targeting high-intent local searches. People actively looking for your services right now.</p>
                    </div>
                    <div class="card stack-3" style="border-left: 3px solid var(--theme-accent-yellow);">
                        <h3 class="t-display t-display--card">META ADS</h3>
                        <p class="t-body t-body--sm">Facebook and Instagram ads for local awareness and seasonal pushes. Visual campaigns that drive action.</p>
                    </div>
                    <div class="card stack-3" style="border-left: 3px solid var(--theme-accent-yellow);">
                        <h3 class="t-display t-display--card">LANDING PAGES</h3>
                        <p class="t-body t-body--sm">Ad-specific pages built for conversion. Not your homepage. Not a generic service page. Built to close.</p>
                    </div>
                    <div class="card stack-3" style="border-left: 3px solid var(--theme-accent-yellow);">
                        <h3 class="t-display t-display--card">RETARGETING</h3>
                        <p class="t-body t-body--sm">People visit. They don't convert. They see you again. And again. Until they're ready.</p>
                    </div>
                    <div class="card stack-3" style="border-left: 3px solid var(--theme-accent-yellow);">
                        <h3 class="t-display t-display--card">AUTOMATED FOLLOW-UP</h3>
                        <p class="t-body t-body--sm">Every ad lead gets the same system follow-up as your other leads. Nothing falls through.</p>
                    </div>
                    <div class="card stack-3" style="border-left: 3px solid var(--theme-accent-yellow);">
                        <h3 class="t-display t-display--card">ONGOING OPTIMIZATION</h3>
                        <p class="t-body t-body--sm">We test. Adjust. Cut waste. Improve targeting. Every dollar works harder month over month.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- PROOF -->
    <section class="section section--padded surface-elevated">
        <div class="grid-page">
            <div class="col-content stack-4">
                <p class="t-eyebrow">What This Looks Like</p>
                <div class="card" style="border-left: 3px solid var(--theme-accent-yellow); padding: var(--space-6);">
                    <p class="t-body t-body--sm" style="color: var(--theme-accent-yellow); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-3);">Case Study — Roofing Company</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-6);">
                        <div class="stack-2">
                            <p style="font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-text-muted);">Before (Ads Only)</p>
                            <p class="t-body t-body--sm">• $8K/mo spend</p>
                            <p class="t-body t-body--sm">• 12% close rate</p>
                            <p class="t-body t-body--sm">• 3.5 hour callback</p>
                            <p class="t-body t-body--sm">• No tracking</p>
                        </div>
                        <div class="stack-2">
                            <p style="font-family: var(--font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--theme-accent-yellow);">After (System + Ads)</p>
                            <p class="t-body t-body--sm" style="color: var(--color-text-primary);">• <strong>Same spend</strong></p>
                            <p class="t-body t-body--sm" style="color: var(--color-text-primary);">• <strong>23% close rate</strong></p>
                            <p class="t-body t-body--sm" style="color: var(--color-text-primary);">• <strong>Under 2 min response</strong></p>
                            <p class="t-body t-body--sm" style="color: var(--color-text-primary);">• <strong>+$14,500/mo revenue</strong></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 4 — INVESTMENT -->
    <section class="section section--statement section--padded surface-base">
        <div class="grid-page">
            <div class="col-content stack-4 text-center">
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    <span style="color: var(--theme-accent-yellow);">$1,500/MONTH</span> MANAGEMENT.<br />
                    <span class="t-accent t-flicker">$1,000/MONTH MIN AD SPEND.</span>
                </h2>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch;">
                    That's the starting line. As your system proves out, you can scale the spend. We'll tell you when it makes sense.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 600;">
                    Volume is only offered after the Foundation is installed. We're not going to burn your money on a broken system.
                </p>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section section--cta section--padded section--mic-drop section--mic-drop--yellow has-scanlines" style="position: relative;">
        <div class="grid-page" style="position: relative; z-index: 2;">
            <div class="col-content text-center stack-4">
                <h2 class="t-display t-display--section" style="color: #fff; margin-inline: auto;">
                    NEED THE FOUNDATION<br />
                    <span class="mic-drop__headline">FIRST?</span>
                </h2>
                <div style="display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap; margin-top: var(--space-4);">
                    <a href="/foundation-install" class="btn btn--lg">Get Your Foundation Installed →</a>
                    <a href="/contact" class="btn btn--lg btn--mic-outline">Ready for Volume? Let's Talk</a>
                </div>
            </div>
        </div>
    </section>

</BaseLayout>
