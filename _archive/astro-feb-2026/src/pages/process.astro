---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Process" description="Fill out a form. We check your stuff. We tell you what's broken. Then we fix it. No mystery. No runaround." currentPage="process">

    <!-- SECTION 1 — HERO -->
    <section class="section section--hero surface-base noise-bg" style="min-height: auto; padding-top: var(--space-24); padding-bottom: var(--space-12);">
        <div class="grid-page">
            <div class="col-content stack-6 text-center">
                <p class="t-eyebrow">How It Works</p>
                <h1 class="t-display t-display--hero" style="margin-inline: auto;">
                    NO MYSTERY.<br />
                    <span style="color: var(--theme-accent-purple);">NO RUNAROUND.</span>
                </h1>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch;">
                    You tell us what's going on. We figure out what's broken. We fix it. You grow. That's the whole thing.
                </p>
            </div>
        </div>
    </section>


    <!-- SECTION 2 — THE 4 STEPS -->
    <section class="section section--padded surface-sunken">
        <div class="grid-page grid-gap-xl">

            <!-- Step 1 -->
            <div class="col-full">
                <div class="grid-page grid-align-center">
                    <div class="col-left-5">
                        <div class="card" style="border: 2px solid var(--color-border); position: relative;">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-4); padding-bottom: var(--space-3); border-bottom: 1px solid var(--color-border);">
                                <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; border: 1px solid var(--color-border); padding: 2px 8px;">TRACK 01</span>
                                <span style="color: var(--color-brand); font-size: 0.75rem;">●</span>
                            </div>
                            <h3 class="t-display t-display--card" style="margin-bottom: var(--space-2);">YOU TELL US WHAT'S GOING ON</h3>
                            <p class="t-body t-body--sm">Fill out the form. Takes a few minutes. Tell us what you do, what's not working, and what you've tried.</p>
                            <!-- Analog slider decoration -->
                            <div style="margin-top: var(--space-4); display: flex; align-items: center; gap: var(--space-2);">
                                <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--color-brand);"></span>
                                <div style="flex: 1; height: 3px; background: linear-gradient(to right, var(--color-text-primary) 25%, var(--color-border) 25%); border-radius: 2px;"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-right-7 stack-4">
                        <p class="t-body t-body--md" style="color: var(--color-text-primary); font-weight: 600;">
                            No sales call first. No calendar link before we know anything about you.
                        </p>
                        <p class="t-body t-body--md">
                            You give us the basics. We read every word. Then we go look at your stuff before we ever get on a call.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="col-full">
                <div class="grid-page grid-align-center">
                    <div class="col-left-5">
                        <div class="card" style="border: 2px solid var(--color-border); position: relative;">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-4); padding-bottom: var(--space-3); border-bottom: 1px solid var(--color-border);">
                                <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; border: 1px solid var(--color-border); padding: 2px 8px;">TRACK 02</span>
                                <span style="color: var(--theme-accent-teal); font-size: 0.75rem;">●</span>
                            </div>
                            <h3 class="t-display t-display--card" style="margin-bottom: var(--space-2);">WE DIAGNOSE</h3>
                            <p class="t-body t-body--sm">We check your site, your Google profile, your tracking, your lead flow. We come to the call with answers, not questions.</p>
                            <div style="margin-top: var(--space-4); display: flex; align-items: center; gap: var(--space-2);">
                                <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--theme-accent-teal);"></span>
                                <div style="flex: 1; height: 3px; background: linear-gradient(to right, var(--color-text-primary) 50%, var(--color-border) 50%); border-radius: 2px;"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-right-7 stack-4">
                        <p class="t-body t-body--md" style="color: var(--color-text-primary); font-weight: 600;">
                            We tell you what's broken. What's missing. And what to fix first.
                        </p>
                        <p class="t-body t-body--md">
                            No hand-waving. No buzzwords. Just a straight diagnosis. If we're a fit, we'll tell you exactly what we'd build and what it costs. If not, we'll point you in the right direction anyway.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Step 3 -->
            <div class="col-full">
                <div class="grid-page grid-align-center">
                    <div class="col-left-5">
                        <div class="card" style="border: 2px solid var(--color-border); position: relative;">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-4); padding-bottom: var(--space-3); border-bottom: 1px solid var(--color-border);">
                                <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; border: 1px solid var(--color-border); padding: 2px 8px;">TRACK 03</span>
                                <span style="color: var(--theme-accent-yellow); font-size: 0.75rem;">●</span>
                            </div>
                            <h3 class="t-display t-display--card" style="margin-bottom: var(--space-2);">WE BUILD IT</h3>
                            <p class="t-body t-body--sm">Your system gets designed, built, connected, and tested. You see it before it goes live. No surprises.</p>
                            <div style="margin-top: var(--space-4); display: flex; align-items: center; gap: var(--space-2);">
                                <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--theme-accent-yellow);"></span>
                                <div style="flex: 1; height: 3px; background: linear-gradient(to right, var(--color-text-primary) 75%, var(--color-border) 75%); border-radius: 2px;"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-right-7 stack-4">
                        <p class="t-body t-body--md" style="color: var(--color-text-primary); font-weight: 600;">
                            You approve everything before it goes live.
                        </p>
                        <p class="t-body t-body--md">
                            You see the site. The automations. The tracking. The follow-up sequences. If something's off, we fix it before launch. Not after.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Step 4 -->
            <div class="col-full">
                <div class="grid-page grid-align-center">
                    <div class="col-left-5">
                        <div class="card" style="border: 2px solid var(--color-border); position: relative;">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-4); padding-bottom: var(--space-3); border-bottom: 1px solid var(--color-border);">
                                <span style="font-family: var(--font-mono); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; border: 1px solid var(--color-border); padding: 2px 8px;">TRACK 04</span>
                                <span style="color: var(--color-brand); font-size: 0.75rem;">●</span>
                            </div>
                            <h3 class="t-display t-display--card" style="margin-bottom: var(--space-2);">LAUNCH + GROW</h3>
                            <p class="t-body t-body--sm">Your system goes live. Leads start flowing. You see the numbers. Then we talk about what comes next.</p>
                            <div style="margin-top: var(--space-4); display: flex; align-items: center; gap: var(--space-2);">
                                <span style="width: 8px; height: 8px; border-radius: 50%; background: var(--color-brand);"></span>
                                <div style="flex: 1; height: 3px; background: var(--color-text-primary); border-radius: 2px;"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-right-7 stack-4">
                        <p class="t-body t-body--md" style="color: var(--color-text-primary); font-weight: 600;">
                            Step 1 done? We talk about Step 2.
                        </p>
                        <p class="t-body t-body--md">
                            When your website system is handling leads and your numbers are solid, we look at local SEO or paid ads. Not before. Growth in the right order. That's the whole play.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 3 — FAQ / COMMON CONCERNS -->
    <section class="section section--padded surface-base">
        <div class="grid-page grid-gap-lg">
            <div class="col-content text-center stack-6">
                <p class="t-eyebrow">Common Questions</p>
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    YEAH, WE GET THAT <span class="t-accent t-flicker">A LOT.</span>
                </h2>
            </div>
            <div class="col-content stack-6">
                <details class="faq-item">
                    <summary class="faq-summary">
                        <span class="t-body t-body--md" style="color: var(--color-text-primary); font-weight: 600;">"I don't even know what I need."</span>
                    </summary>
                    <p class="t-body t-body--sm faq-answer">That's literally why Step 1 is a diagnostic, not a sales pitch. We figure it out. You don't have to come with answers — just tell us what's not working.</p>
                </details>
                <details class="faq-item">
                    <summary class="faq-summary">
                        <span class="t-body t-body--md" style="color: var(--color-text-primary); font-weight: 600;">"How long does it take?"</span>
                    </summary>
                    <p class="t-body t-body--sm faq-answer">Foundation packages take 2-3 weeks. Growth systems take 4-6 weeks. Custom builds depend on scope. We'll give you a timeline before we start.</p>
                </details>
                <details class="faq-item">
                    <summary class="faq-summary">
                        <span class="t-body t-body--md" style="color: var(--color-text-primary); font-weight: 600;">"I've been burned by agencies before."</span>
                    </summary>
                    <p class="t-body t-body--sm faq-answer">Most of our clients have. That's usually why they found us. We don't do long-term contracts, we don't hide behind reports, and we don't ghost after launch.</p>
                </details>
                <details class="faq-item">
                    <summary class="faq-summary">
                        <span class="t-body t-body--md" style="color: var(--color-text-primary); font-weight: 600;">"Do I have to sign a long contract?"</span>
                    </summary>
                    <p class="t-body t-body--sm faq-answer">Nope. Project work is project-priced. Ongoing services are month-to-month. You stay because it works, not because of fine print.</p>
                </details>
                <details class="faq-item">
                    <summary class="faq-summary">
                        <span class="t-body t-body--md" style="color: var(--color-text-primary); font-weight: 600;">"I just need a website."</span>
                    </summary>
                    <p class="t-body t-body--sm faq-answer">Cool. We build those. But we build them with lead capture, follow-up, tracking, and CRM connected from day one. Because a website without a system is a brochure. And brochures don't book jobs.</p>
                </details>
            </div>
        </div>
    </section>

    <!-- SECTION 4 — CTA -->
    <section class="section section--cta section--padded section--mic-drop section--mic-drop--purple has-scanlines" style="position: relative;">
        <div class="grid-page" style="position: relative; z-index: 2;">
            <div class="col-content text-center stack-4">
                <h2 class="t-display t-display--section" style="color: #fff; margin-inline: auto;">
                    READY TO FIND OUT<br />
                    <span class="mic-drop__headline">WHAT'S BROKEN?</span>
                </h2>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 50ch; margin-top: var(--space-4);">
                    10 minutes. No obligation. No pitch. Just a straight answer about what's working and what's not.
                </p>
                <a href="/contact" class="btn btn--lg">Diagnose Your System →</a>
            </div>
        </div>
    </section>

    <!-- REINFORCEMENT -->
    <section class="section section--statement section--padded-sm surface-pure">
        <div class="grid-page">
            <div class="col-content text-center">
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 500;">
                    You tell us. We diagnose. We build. You grow. No mystery. No magic. Just work that works.
                </p>
            </div>
        </div>
    </section>

</BaseLayout>

<style>
    .faq-item {
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-4) 0;
    }
    .faq-summary {
        cursor: pointer;
        list-style: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .faq-summary::-webkit-details-marker { display: none; }
    .faq-summary::after {
        content: '+';
        font-family: var(--font-mono);
        font-size: 1.25rem;
        color: var(--color-brand);
        transition: transform 0.2s ease;
    }
    details[open] .faq-summary::after {
        content: '−';
    }
    .faq-answer {
        margin-top: var(--space-3);
        padding-left: var(--space-4);
        border-left: 2px solid var(--color-border);
    }
</style>
