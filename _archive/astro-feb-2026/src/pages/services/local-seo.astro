---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Local SEO" description="Get in front of people already looking for what you do. Google Maps. Service pages. Real local visibility." currentPage="local-seo">

    <!-- SECTION 1 — HERO -->
    <section class="section section--hero surface-base noise-bg">
        <div class="grid-page grid-align-center">
            <div class="col-left-7 stack-6">
                <p class="t-eyebrow" style="color: var(--theme-accent-teal);">Step 2 — Get Found</p>
                <h1 class="t-display t-display--hero">
                    THEY'RE SEARCHING<br />FOR YOU.<br />
                    <span style="color: var(--theme-accent-teal);">AND FINDING YOUR COMPETITOR.</span>
                </h1>
                <p class="t-body t-body--lg" style="max-width: 55ch;">
                    People in your area are Googling what you do right now. And they're hiring whoever shows up first. If that's not you, it doesn't matter how good your work is.
                </p>
                <p class="t-body t-body--md" style="max-width: 55ch; color: var(--color-text-primary); font-weight: 500;">
                    You don't have a marketing problem. You have a visibility problem.
                </p>
                <a href="/contact" class="btn btn--primary btn--lg" style="background: var(--theme-accent-teal); border-color: var(--theme-accent-teal); color: var(--color-surface-base);">Get Found →</a>
            </div>
            <div class="col-right-5">
                <div style="aspect-ratio: 4/5; background: var(--color-surface-elevated); border: 1px solid var(--color-border); display: flex; align-items: center; justify-content: center;">
                    <img src="/images/logos/badmouth-logo-stacked.png" alt="Badmouth Digital" style="width: 60%; opacity: 0.15;" />
                </div>
            </div>
        </div>
    </section>

    <hr class="section-divider" style="background: var(--theme-accent-teal);" />

    <!-- SECTION 2 — PROBLEM -->
    <section class="section section--split section--padded surface-sunken">
        <div class="grid-page grid-align-center grid-gap-lg">
            <div class="col-left-7 stack-6">
                <p class="t-eyebrow">Why You Don't Rank</p>
                <h2 class="t-display t-display--section">
                    YOU CAN'T RANK<br />
                    <span class="t-accent t-crt-shake">IF YOU HAVE NOTHING TO RANK.</span>
                </h2>
                <p class="t-body t-body--md" style="max-width: 55ch;">
                    You've got a 5-page website. One home page. One about. One contact. Maybe a services page that lists everything you do in one paragraph.
                </p>
                <p class="t-body t-body--md" style="max-width: 55ch;">
                    Google needs pages. Unique pages for each service. For each area. With real content. That's how you show up in Maps and in search. Not with one generic page and a prayer.
                </p>
            </div>
            <div class="col-right-5">
                <div class="card stack-3" style="border-left: 3px solid var(--theme-accent-teal);">
                    <p class="t-body t-body--sm" style="color: var(--theme-accent-teal); font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">This Only Works If</p>
                    <p class="t-body t-body--sm">Your website system is built (Step 1).</p>
                    <p class="t-body t-body--sm">Your site can convert the traffic we send.</p>
                    <p class="t-body t-body--sm">Your follow-up catches the leads.</p>
                    <p class="t-body t-body--sm" style="color: var(--color-text-muted); margin-top: var(--space-2);">If Step 1 isn't done, we start there. No arguments.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 3 — WHAT'S INCLUDED -->
    <section class="section section--padded surface-base">
        <div class="grid-page grid-gap-lg">
            <div class="col-full text-center stack-6">
                <p class="t-eyebrow" style="color: var(--theme-accent-teal);">The Local Map Growth System</p>
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    HERE'S WHAT WE <span style="color: var(--theme-accent-teal);">BUILD.</span>
                </h2>
            </div>
            <div class="col-full">
                <div class="inner-grid-3">
                    <div class="card stack-3">
                        <h3 class="t-display t-display--card">GOOGLE PROFILE OPTIMIZATION</h3>
                        <p class="t-body t-body--sm">Full audit and optimization of your Google Business Profile. Categories, attributes, photos, posts, Q&A. The works.</p>
                    </div>
                    <div class="card stack-3">
                        <h3 class="t-display t-display--card">SERVICE PAGES</h3>
                        <p class="t-body t-body--sm">Individual pages for each service you offer. Written for humans, structured for Google. New pages every week.</p>
                    </div>
                    <div class="card stack-3">
                        <h3 class="t-display t-display--card">AREA PAGES</h3>
                        <p class="t-body t-body--sm">Pages targeting every city, town, and neighborhood you serve. So Google knows where you work.</p>
                    </div>
                    <div class="card stack-3">
                        <h3 class="t-display t-display--card">ON-PAGE SEO</h3>
                        <p class="t-body t-body--sm">Title tags, meta descriptions, headers, schema markup. Every page optimized to rank, not just to exist.</p>
                    </div>
                    <div class="card stack-3">
                        <h3 class="t-display t-display--card">CITATION BUILDING</h3>
                        <p class="t-body t-body--sm">Consistent business info across directories. Google trusts businesses that show up the same everywhere.</p>
                    </div>
                    <div class="card stack-3">
                        <h3 class="t-display t-display--card">MONTHLY REPORTING</h3>
                        <p class="t-body t-body--sm">Rankings, traffic, calls, form fills. Real numbers. No vanity metrics. You'll know exactly what's happening.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <hr class="section-divider" />

    <!-- SECTION 4 — PRICING -->
    <section class="section section--statement section--padded surface-elevated">
        <div class="grid-page grid-gap-lg">
            <div class="col-content text-center stack-6">
                <p class="t-eyebrow">Pricing</p>
                <h2 class="t-display t-display--section" style="margin-inline: auto;">
                    <span style="color: var(--theme-accent-teal);">$2,500</span> / MONTH
                </h2>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch;">
                    Monthly SEO management. New pages every week. Ongoing optimization. Real reporting.
                </p>
                <p class="t-body t-body--md" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 500;">
                    No long-term contracts. Month-to-month. We earn your business or you walk.
                </p>
                <a href="/contact" class="btn btn--primary btn--lg" style="background: var(--theme-accent-teal); border-color: var(--theme-accent-teal); color: var(--color-surface-base);">Request Local SEO →</a>
            </div>
        </div>
    </section>

    <!-- SECTION 5 — CTA -->
    <section class="section section--cta section--padded section--mic-drop section--mic-drop--teal has-scanlines" style="position: relative;">
        <div class="grid-page" style="position: relative; z-index: 2;">
            <div class="col-content text-center stack-4">
                <h2 class="t-display t-display--section" style="color: #fff; margin-inline: auto;">
                    STOP BEING<br />
                    <span class="mic-drop__headline">INVISIBLE.</span>
                </h2>
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 50ch; margin-top: var(--space-4);">
                    People are searching for what you do right now. Let's make sure they find you.
                </p>
                <a href="/contact" class="btn btn--lg">Get Found →</a>
            </div>
        </div>
    </section>

    <!-- REINFORCEMENT -->
    <section class="section section--statement section--padded-sm surface-pure">
        <div class="grid-page">
            <div class="col-content text-center">
                <p class="t-body t-body--lg" style="margin-inline: auto; max-width: 55ch; color: var(--color-text-primary); font-weight: 500;">
                    Rankings without a converting website are useless. That's why Step 2 comes after Step 1.
                </p>
            </div>
        </div>
    </section>

</BaseLayout>
